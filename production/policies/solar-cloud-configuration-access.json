{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCreateWithEnvSolarDev",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "ec2:CreateSecurityGroup",
        "ec2:CreateVpc",
        "ec2:CreateVpcEndpoint",
        "ec2:CreateSubnet",
        "ec2:CreateInternetGateway",
        "ec2:CreateNatGateway",
        "ec2:CreateRouteTable",
        "ec2:CreateRoute",
        "ec2:CreateTags",
        "ec2:DescribeInstances",
        "ec2:AssociateIamInstanceProfile",
        "ec2:AllocateAddress",
        "ec2:AssociateAddress",
        "ec2:ReleaseAddress",
        "ec2:ModifyVolume",
        "ec2:AttachVolume",
        "ec2:DeleteVolume",
        "ec2:CreateNetworkInterface",
        "ec2:AttachNetworkInterface",
        "ec2:CreateKeyPair",
        "ec2:ImportKeyPair",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupIngress",
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:RevokeSecurityGroupEgress",
        "ec2:DescribeSecurityGroups",
        "ec2:DeleteSecurityGroup",
        "ec2:DetachNetworkInterface",
        "ec2:DeleteNetworkInterface",
        "rds:DescribeDBInstances",
        "rds:DescribeDBSubnetGroups",
        "rds:DescribeDBEngineVersions",
        "rds:DescribeOptionGroups",
        "rds:DescribeOrderableDBInstanceOptions",
        "rds:DescribeDBParameterGroups",
        "rds:CreateDBInstance",
        "rds:CreateDBSubnetGroup",
        "ssm:StartSession",
        "ssm:DescribeSessions",
        "ssm:GetConnectionStatus",
        "ssm:TerminateSession"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowRDSSecretsManager",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:CreateSecret",
        "secretsmanager:DescribeSecret",
        "secretsmanager:PutSecretValue",
        "secretsmanager:TagResource"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowManageOnlyEnvSolarDevResources",
      "Effect": "Allow",
      "Action": [
        "ec2:*",
        "rds:*",
        "lambda:*",
        "s3:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/env": "production"
        }
      }
    },
    {
      "Sid": "AllowIamReadForEC2Console",
      "Effect": "Allow",
      "Action": [
        "iam:ListRoles",
        "iam:GetRole",
        "iam:ListInstanceProfiles",
        "iam:GetInstanceProfile"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowPassOnlySolarDevRolesToEC2",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::835661413932:role/*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "iam:PassedToService": [
            "ec2.amazonaws.com",
            "rds.amazonaws.com",
            "monitoring.rds.amazonaws.com"
          ]
        }
      }
    }
  ]
}

