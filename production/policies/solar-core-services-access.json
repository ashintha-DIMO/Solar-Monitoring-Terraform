{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowUseOfTaggedEC2Instances",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:GetConsoleOutput",
        "ec2:StartInstances",
        "ec2:StopInstances",
        "ec2:RebootInstances",
        "ec2:MonitorInstances"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowSessionManagerAccessToTaggedInstances",
      "Effect": "Allow",
      "Action": [
        "ssm:StartSession",
        "ssm:DescribeInstanceInformation",
        "ssm:GetConnectionStatus",
        "ssm:DescribeSessions",
        "ssm:TerminateSession",
        "ssm:GetDocument",
        "ssm:DescribeDocument",
        "ssm:SendCommand",
        "ssm:ListCommandInvocations",
        "ssm:ListCommands"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowUseOfTaggedLambdaAndStorage",
      "Effect": "Allow",
      "Action": [
        "lambda:InvokeFunction",
        "lambda:GetFunction",
        "lambda:ListVersionsByFunction",
        "s3:GetObject",
        "s3:ListBucket",
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "iot:DescribeThing",
        "iot:GetThingShadow",
        "logs:GetLogEvents",
        "logs:DescribeLogStreams"
      ],
      "Resource": "*"
    },
    {
      "Sid": "S3ListBucketSpecific",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::dimo-solar-s3-bucket-production-apse1"
    },
    {
      "Sid": "S3ObjectRWXSpecific",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectAttributes",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListBucketMultipartUploads",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": "arn:aws:s3:::dimo-solar-s3-bucket-production-apse1/*"
    },
    {
      "Sid": "AllowMetadataReadAccess",
      "Effect": "Allow",
      "Action": [
        "ec2:Describe*",
        "lambda:List*",
        "s3:ListAllMyBuckets",
        "dynamodb:ListTables",
        "iot:ListThings",
        "logs:Describe*",
        "cloudwatch:Describe*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyProvisioningAndIAM",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:TerminateInstances",
        "ec2:CreateImage",
        "ec2:CreateTags",
        "s3:CreateBucket",
        "lambda:CreateFunction",
        "dynamodb:CreateTable",
        "iot:CreateThing",
        "iam:*"
      ],
      "Resource": "*"
    }
  ]
}

